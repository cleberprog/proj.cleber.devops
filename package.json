{
  "name": "cleber-developer-portfolio",
  "version": "1.1.0",
  "description": "Portfolio digital moderno com HTML5, CSS3 e JavaScript Vanilla",
  "main": "script.js",
  "scripts": {
    "start": "npm run serve",
    "serve": "python -m http.server 8000 || npx http-server -p 8000",
    "lint": "eslint . --ext .js --ignore-path .gitignore",
    "lint:fix": "eslint . --ext .js --fix --ignore-path .gitignore",
    "format": "prettier --write \"**/*.{js,html,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,html,css,json,md}\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=html",
    "build": "npm run build:css && npm run build:js",
    "build:css": "cleancss -o style.min.css style.css",
    "build:js": "terser script.js -o script.min.js -c -m",
    "prepare": "husky install",
    "pre-commit": "lint-staged"
  },
  "keywords": [
    "portfolio",
    "html5",
    "css3",
    "javascript",
    "spa",
    "responsive"
  ],
  "author": "Cleber Developer",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.1.5",
    "cleancss-cli": "^5.6.2",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.0",
    "terser": "^5.26.0"
  },
  "dependencies": {},
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cleberprog/proj.cleber.devops.git"
  },
  "homepage": "https://github.com/cleberprog/proj.cleber.devops#readme",
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,css,json,md}": [
      "prettier --write"
    ]
  }
}
